{
  "$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"permission": {
		"bash": {
			"git checkout": "ask",
			"git push": "ask",
			"git reset": "ask",
			"git commit": "ask",
			"git stash": "ask",
			"git restore": "ask"
		}
  },
	"mcp": {
		"vuetify-mcp": {
			"type": "remote",
			"url": "https://mcp.vuetifyjs.com/mcp",
			"enabled": true,
			"headers": {
				"Authorization": "Bearer <token>"
			}
		},
		"playwright": {
			"type": "local",
			"command": ["pnpx", "@playwright/mcp@latest"],
			"enabled": true
		},
		"sentry": {
			"type": "remote",
			"url": "https://mcp.sentry.dev/mcp",
			"enabled": true
		},
		"jira": {
			"type": "remote",
			"url": "https://mcp.atlassian.com/v1/mcp",
			"enabled": true
		}
	}
}
